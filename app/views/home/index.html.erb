    <script data-turbolinks-eval="false">
        // 导航栏滚动效果
        window.addEventListener('scroll', function() {
            const navbar = document.getElementById('navbar');
            if (navbar && window.scrollY > 50) {
                navbar.classList.add('scrolled');
            } else if (navbar) {
                navbar.classList.remove('scrolled');
            }
        });
        
        // 轮播图功能
        function initCarousel() {
            let currentSlide = 0;
            const slides = document.querySelectorAll('.carousel-slide');
            const indicators = document.querySelectorAll('.indicator');
            
            if (slides.length === 0 || indicators.length === 0) return;
            
            function showSlide(index) {
                slides.forEach(slide => slide.classList.remove('active'));
                indicators.forEach(indicator => indicator.classList.remove('active'));
                
                slides[index].classList.add('active');
                indicators[index].classList.add('active');
                currentSlide = index;
            }
            
            window.goToSlide = function(index) {
                showSlide(index);
            };
            
            function nextSlide() {
                let next = currentSlide + 1;
                if (next >= slides.length) next = 0;
                showSlide(next);
            }
            
            // 自动轮播
            setInterval(nextSlide, 5000);
        }
        
        // 平滑滚动
        function initSmoothScroll() {
            document.querySelectorAll('a[href^="#"]').forEach(anchor => {
                // 跳过退出登录链接
                if (anchor.id === 'logout-link') {
                    return;
                }
                anchor.addEventListener('click', function(e) {
                    const href = this.getAttribute('href');
                    // 跳过href只是"#"的链接
                    if (href === '#') {
                        return;
                    }
                    e.preventDefault();
                    const target = document.querySelector(href);
                    if (target) {
                        target.scrollIntoView({ 
                            behavior: 'smooth',
                            block: 'start'
                        });
                    }
                });
            });
        }
        
        // 下拉菜单控制
        function initUserDropdown() {
            const userDropdown = document.querySelector('.user-dropdown');
            const dropdownMenu = document.querySelector('.dropdown-menu');
            let isOpenByClick = false;
            let hoverTimeout;
            
            if (userDropdown && dropdownMenu) {
                // 确保用户头像可聚焦
                userDropdown.setAttribute('tabindex', '0');
                userDropdown.setAttribute('role', 'button');
                userDropdown.setAttribute('aria-haspopup', 'true');
                userDropdown.setAttribute('aria-expanded', 'false');
                
                // 定义事件处理函数
                function handleClick(e) {
                    e.stopPropagation();
                    isOpenByClick = !isOpenByClick;
                    dropdownMenu.classList.toggle('show');
                    userDropdown.setAttribute('aria-expanded', dropdownMenu.classList.contains('show'));
                }
                
                function handleMouseEnter() {
                    clearTimeout(hoverTimeout);
                    if (!isOpenByClick) {
                        dropdownMenu.classList.add('show');
                        userDropdown.setAttribute('aria-expanded', 'true');
                    }
                }
                
                function handleMouseLeave() {
                    if (!isOpenByClick) {
                        hoverTimeout = setTimeout(() => {
                            dropdownMenu.classList.remove('show');
                            userDropdown.setAttribute('aria-expanded', 'false');
                        }, 200);
                    }
                }
                
                function handleClickOutside(e) {
                    if (!userDropdown.contains(e.target) && !dropdownMenu.contains(e.target)) {
                        dropdownMenu.classList.remove('show');
                        isOpenByClick = false;
                        userDropdown.setAttribute('aria-expanded', 'false');
                    }
                }
                
                function handleKeyDown(e) {
                    if (e.key === 'Enter' || e.key === ' ') {
                        e.preventDefault();
                        handleClick(e);
                    } else if (e.key === 'Escape') {
                        dropdownMenu.classList.remove('show');
                        isOpenByClick = false;
                        userDropdown.setAttribute('aria-expanded', 'false');
                    }
                }
                
                // 添加事件监听器
                userDropdown.addEventListener('click', handleClick);
                userDropdown.addEventListener('mouseenter', handleMouseEnter);
                userDropdown.addEventListener('mouseleave', handleMouseLeave);
                dropdownMenu.addEventListener('mouseenter', handleMouseEnter);
                dropdownMenu.addEventListener('mouseleave', handleMouseLeave);
                userDropdown.addEventListener('keydown', handleKeyDown);
                document.addEventListener('click', handleClickOutside);
            }
        }
        
        // 退出登录功能
        function initLogout() {
            // 直接在DOM中查找退出登录按钮，确保即使在动态加载的内容中也能找到
            const logoutBtn = document.querySelector('.logout-btn');
            const logoutForm = document.querySelector('.dropdown-menu form');
            
            if (logoutBtn && logoutForm) {
                // 定义事件处理函数
                function handleLogoutClick(e) {
                    // 阻止事件冒泡，确保不会触发userDropdown的点击事件
                    e.stopPropagation();
                    
                    // 提交表单，使用表单的默认行为
                    logoutForm.submit();
                }
                
                // 添加点击事件监听器
                logoutBtn.addEventListener('click', handleLogoutClick);
            }
        }
        
        // 初始化所有功能
        function initPage() {
            initCarousel();
            initSmoothScroll();
            initUserDropdown();
            initLogout();
        }
        
        // 同时支持传统页面加载和Turbolinks
        document.addEventListener('DOMContentLoaded', initPage);
        document.addEventListener('turbolinks:load', initPage);
    </script>
