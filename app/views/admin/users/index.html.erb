<% content_for :title, '用户管理' %>

<div class="card">
  <div class="card-header">
    <h3>用户列表</h3>
  </div>
  <table class="table">
    <thead>
      <tr>
        <th>用户名</th>
        <th>邮箱</th>
        <th>注册时间</th>
        <th>注册IP</th>
        <th>最后登录</th>
        <th>登录IP</th>
        <th>状态</th>
        <th>角色</th>
        <th>操作</th>
      </tr>
    </thead>
    <tbody>
      <% @users.each do |user| %>
        <tr>
          <td><%= user.username %></td>
          <td><%= user.email %></td>
          <td><%= user.created_at.strftime('%Y-%m-%d %H:%M') %></td>
          <td><%= user.registration_ip || '-' %></td>
          <td><%= user.last_sign_in_at&.strftime('%Y-%m-%d %H:%M') || '-' %></td>
          <td><%= user.last_sign_in_ip || '-' %></td>
          <td>
            <span class="status-badge <%= user.online? ? 'status-online' : 'status-offline' %>">
              <%= user.online? ? '在线' : '离线' %>
            </span>
          </td>
          <td><%= user.role&.name || (user.is_admin? ? '超级管理员' : '普通用户') %></td>
          <td>
            <%= link_to '查看', admin_user_path(user), class: 'btn btn-primary btn-sm' %>
            <%= link_to '编辑', edit_admin_user_path(user), class: 'btn btn-secondary btn-sm' %>
            <%= link_to '删除', admin_user_path(user), method: :delete, data: { confirm: '确定删除该用户吗？' }, class: 'btn btn-danger btn-sm' %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
  <%= paginate @users %>
</div>
