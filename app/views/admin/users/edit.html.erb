<% content_for :title, "编辑用户 - #{@user.username}" %>

<div class="card">
  <div class="card-header">
    <h3>编辑用户</h3>
    <div>
      <%= link_to '返回', admin_user_path(@user), class: 'btn btn-secondary' %>
    </div>
  </div>
  <%= form_with(model: [:admin, @user], local: true) do |form| %>
    <% if @user.errors.any? %>
      <div class="alert alert-danger">
        <% @user.errors.full_messages.each do |msg| %>
          <p><%= msg %></p>
        <% end %>
      </div>
    <% end %>
    <div class="form-group">
      <%= form.label :username %>
      <%= form.text_field :username, class: 'form-control' %>
    </div>
    <div class="form-group">
      <%= form.label :email %>
      <%= form.email_field :email, class: 'form-control' %>
    </div>
    <div class="form-group">
      <%= form.label :role_id %>
      <%= form.select :role_id, @roles.map { |r| [r.name, r.id] }, { include_blank: '无角色' }, class: 'form-control' %>
    </div>
    <div class="form-group">
      <%= form.label :is_admin %>
      <%= form.check_box :is_admin %>
    </div>
    <div class="form-group">
      <%= form.label :online_status %>
      <%= form.select :online_status, ['online', 'offline'], {}, class: 'form-control' %>
    </div>
    <div class="form-group">
      <%= form.submit '保存', class: 'btn btn-primary' %>
      <%= link_to '取消', admin_user_path(@user), class: 'btn btn-secondary' %>
    </div>
  <% end %>
</div>
