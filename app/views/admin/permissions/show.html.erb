<% content_for :title, "权限详情 - #{@permission.name}" %>

<div class="card">
  <div class="card-header">
    <h3>权限信息</h3>
    <div>
      <%= link_to '编辑', edit_admin_permission_path(@permission), class: 'btn btn-primary' %>
      <%= link_to '返回列表', admin_permissions_path, class: 'btn btn-secondary' %>
    </div>
  </div>
  <div class="grid grid-2">
    <div>
      <p><strong>名称:</strong> <%= @permission.name %></p>
      <p><strong>资源:</strong> <%= @permission.resource %></p>
      <p><strong>操作:</strong> <%= @permission.action %></p>
      <p><strong>描述:</strong> <%= @permission.description %></p>
    </div>
    <div>
      <p><strong>角色数量:</strong> <%= @permission.roles.count %></p>
      <p><strong>创建时间:</strong> <%= @permission.created_at.strftime('%Y-%m-%d %H:%M') %></p>
    </div>
  </div>
  <% if @permission.roles.any? %>
    <div style="margin-top: 20px;">
      <h4>关联角色</h4>
      <ul>
        <% @permission.roles.each do |role| %>
          <li><%= role.name %></li>
        <% end %>
      </ul>
    </div>
  <% end %>
</div>
