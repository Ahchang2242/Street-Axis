<%= form_with(model: [:admin, permission], local: true) do |form| %>
  <% if permission.errors.any? %>
    <div class="alert alert-danger">
      <% permission.errors.full_messages.each do |msg| %>
        <p><%= msg %></p>
      <% end %>
    </div>
  <% end %>
  <div class="form-group">
    <%= form.label :name %>
    <%= form.text_field :name, class: 'form-control' %>
  </div>
  <div class="form-group">
    <%= form.label :resource %>
    <%= form.text_field :resource, class: 'form-control' %>
  </div>
  <div class="form-group">
    <%= form.label :action %>
    <%= form.text_field :action, class: 'form-control' %>
  </div>
  <div class="form-group">
    <%= form.label :description %>
    <%= form.text_area :description, class: 'form-control', rows: 3 %>
  </div>
  <div class="form-group">
    <%= form.submit '保存', class: 'btn btn-primary' %>
    <%= link_to '取消', permission.persisted? ? admin_permission_path(permission) : admin_permissions_path, class: 'btn btn-secondary' %>
  </div>
<% end %>
