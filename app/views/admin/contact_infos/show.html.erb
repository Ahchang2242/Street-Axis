<% content_for :title, '联系我们' %>

<div class="card">
  <div class="card-header">
    <h3>联系我们</h3>
    <%= link_to '编辑', edit_admin_contact_info_path, class: 'btn btn-primary' %>
  </div>
  <div class="form-group">
    <label>地址</label>
    <p><%= @contact_info.address %></p>
  </div>
  <div class="form-group">
    <label>电话</label>
    <p><%= @contact_info.phone %></p>
  </div>
  <div class="form-group">
    <label>邮箱</label>
    <p><%= @contact_info.email %></p>
  </div>
  <div class="form-group">
    <label>营业时间</label>
    <p><%= @contact_info.business_hours %></p>
  </div>
</div>
