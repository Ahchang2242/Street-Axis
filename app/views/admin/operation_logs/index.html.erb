<% content_for :title, '操作日志' %>

<div class="card">
  <div class="card-header">
    <h3>操作日志</h3>
  </div>
  <div class="card" style="margin-bottom: 20px;">
    <%= form_with url: admin_operation_logs_path, method: :get, local: true do |form| %>
      <div class="grid grid-4">
        <div class="form-group">
          <%= form.label :user_id, '操作人' %>
          <%= form.select :user_id, @users.map { |u| [u.username, u.id] }, { include_blank: '全部' }, class: 'form-control' %>
        </div>
        <div class="form-group">
          <%= form.label :action_type, '操作类型' %>
          <%= form.select :action_type, @actions, { include_blank: '全部' }, class: 'form-control' %>
        </div>
        <div class="form-group">
          <%= form.label :start_date, '开始日期' %>
          <%= form.date_field :start_date, class: 'form-control' %>
        </div>
        <div class="form-group">
          <%= form.label :end_date, '结束日期' %>
          <%= form.date_field :end_date, class: 'form-control' %>
        </div>
      </div>
      <div class="form-group">
        <%= form.submit '查询', class: 'btn btn-primary' %>
        <%= link_to '重置', admin_operation_logs_path, class: 'btn btn-secondary' %>
      </div>
    <% end %>
  </div>
  <table class="table">
    <thead>
      <tr>
        <th>ID</th>
        <th>操作人</th>
        <th>操作类型</th>
        <th>资源类型</th>
        <th>资源ID</th>
        <th>IP地址</th>
        <th>时间</th>
        <th>操作</th>
      </tr>
    </thead>
    <tbody>
      <% @logs.each do |log| %>
        <tr>
          <td><%= log.id %></td>
          <td><%= log.user&.username || '系统' %></td>
          <td><%= log.action %></td>
          <td><%= log.resource_type || '-' %></td>
          <td><%= log.resource_id || '-' %></td>
          <td><%= log.ip_address || '-' %></td>
          <td><%= log.created_at.strftime('%Y-%m-%d %H:%M:%S') %></td>
          <td>
            <%= link_to '详情', admin_operation_log_path(log), class: 'btn btn-primary btn-sm' %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
  <%= paginate @logs %>
</div>
