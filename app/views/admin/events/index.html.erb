<% content_for :title, '最新活动管理' %>

<div class="card">
  <div class="card-header">
    <h3>最新活动列表</h3>
    <%= link_to '新建活动', new_admin_event_path, class: 'btn btn-primary' %>
  </div>
  <table class="table">
    <thead>
      <tr>
        <th>标题</th>
        <th>日期</th>
        <th>描述</th>
        <th>创建时间</th>
        <th>操作</th>
      </tr>
    </thead>
    <tbody>
      <% @events.each do |event| %>
        <tr>
          <td><%= event.title %></td>
          <td><%= event.date.strftime('%Y-%m-%d') %></td>
          <td><%= truncate(event.description, length: 50) %></td>
          <td><%= event.created_at.strftime('%Y-%m-%d %H:%M') %></td>
          <td>
            <%= link_to '查看', admin_event_path(event), class: 'btn btn-primary btn-sm' %>
            <%= link_to '编辑', edit_admin_event_path(event), class: 'btn btn-secondary btn-sm' %>
            <%= link_to '删除', admin_event_path(event), method: :delete, data: { confirm: '确定删除该活动吗？' }, class: 'btn btn-danger btn-sm' %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
  <%= paginate @events %>
</div>
