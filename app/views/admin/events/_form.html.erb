<%= form_for([:admin, event], html: { multipart: true }) do |f| %>
  <% if event.errors.any? %>
    <div class="alert alert-danger">
      <h4><%= pluralize(event.errors.count, "error") %> 禁止该内容保存:</h4>
      <ul>
        <% event.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="form-group">
    <%= f.label :title %>
    <%= f.text_field :title, class: 'form-control', required: true %>
  </div>

  <div class="form-group">
    <%= f.label :date %>
    <%= f.date_field :date, class: 'form-control', required: true %>
  </div>

  <div class="form-group">
    <%= f.label :description %>
    <%= f.text_area :description, class: 'form-control', rows: 8, required: true %>
  </div>

  <%= render 'admin/shared/image_upload', f: f, object: event, remove_image_path: (event.persisted? ? remove_uploaded_image_admin_event_path(event) : nil) %>

  <div class="form-actions">
    <%= f.submit '保存', class: 'btn btn-primary' %>
    <%= link_to '取消', admin_events_path, class: 'btn btn-secondary' %>
  </div>
<% end %>
