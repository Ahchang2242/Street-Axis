<%= form_with(model: [:admin, role], local: true) do |form| %>
  <% if role.errors.any? %>
    <div class="alert alert-danger">
      <% role.errors.full_messages.each do |msg| %>
        <p><%= msg %></p>
      <% end %>
    </div>
  <% end %>
  <div class="form-group">
    <%= form.label :name %>
    <%= form.text_field :name, class: 'form-control' %>
  </div>
  <div class="form-group">
    <%= form.label :description %>
    <%= form.text_area :description, class: 'form-control', rows: 3 %>
  </div>
  <div class="form-group">
    <%= form.label :is_active %>
    <%= form.check_box :is_active %>
  </div>
  <% if permissions.any? %>
    <div class="form-group">
      <%= form.label :permissions %>
      <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 10px;">
        <% permissions.each do |perm| %>
          <label style="display: flex; align-items: center; gap: 8px;">
            <%= check_box_tag 'permission_ids[]', perm.id, role.permissions.include?(perm) %>
            <%= perm.name %>
          </label>
        <% end %>
      </div>
    </div>
  <% end %>
  <div class="form-group">
    <%= form.submit '保存', class: 'btn btn-primary' %>
    <%= link_to '取消', role.persisted? ? admin_role_path(role) : admin_roles_path, class: 'btn btn-secondary' %>
  </div>
<% end %>
