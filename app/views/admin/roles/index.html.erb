<% content_for :title, '角色管理' %>

<div class="card">
  <div class="card-header">
    <h3>角色列表</h3>
    <%= link_to '新建角色', new_admin_role_path, class: 'btn btn-primary' %>
  </div>
  <table class="table">
    <thead>
      <tr>
        <th>名称</th>
        <th>描述</th>
        <th>状态</th>
        <th>权限数量</th>
        <th>用户数量</th>
        <th>操作</th>
      </tr>
    </thead>
    <tbody>
      <% @roles.each do |role| %>
        <tr>
          <td><%= role.name %></td>
          <td><%= truncate(role.description, length: 50) %></td>
          <td>
            <span class="status-badge <%= role.is_active ? 'status-active' : 'status-inactive' %>">
              <%= role.is_active ? '启用' : '禁用' %>
            </span>
          </td>
          <td><%= role.permissions.count %></td>
          <td><%= role.users.count %></td>
          <td>
            <%= link_to '查看', admin_role_path(role), class: 'btn btn-primary btn-sm' %>
            <%= link_to '编辑', edit_admin_role_path(role), class: 'btn btn-secondary btn-sm' %>
            <%= link_to '删除', admin_role_path(role), method: :delete, data: { confirm: '确定删除该角色吗？' }, class: 'btn btn-danger btn-sm' %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
  <%= paginate @roles %>
</div>
