<% content_for :title, '关于我们' %>

<div class="card">
  <div class="card-header">
    <h3>关于我们</h3>
    <%= link_to '编辑', edit_admin_about_us_path, class: 'btn btn-primary' %>
  </div>
  <div class="form-group">
    <label>使命</label>
    <p><%= @about_us.mission %></p>
  </div>
  <div class="form-group">
    <label>教学理念</label>
    <p><%= @about_us.teaching_philosophy %></p>
  </div>
  <% if @about_us.image.present? %>
    <div class="form-group">
      <label>图片</label>
      <p><%= @about_us.image %></p>
    </div>
  <% end %>
</div>
