<% content_for :title, '街舞分类详情' %>

<div class="card">
  <div class="card-header">
    <h3><%= @dance_style.name %></h3>
    <div>
      <%= link_to '编辑', edit_admin_dance_style_path(@dance_style), class: 'btn btn-secondary' %>
      <%= link_to '返回列表', admin_dance_styles_path, class: 'btn btn-primary' %>
    </div>
  </div>
  <div class="form-group">
    <label>名称</label>
    <p><%= @dance_style.name %></p>
  </div>
  <div class="form-group">
    <label>描述</label>
    <p><%= @dance_style.description %></p>
  </div>
  <div class="form-group">
    <label>创建时间</label>
    <p><%= @dance_style.created_at.strftime('%Y-%m-%d %H:%M:%S') %></p>
  </div>
  <div class="form-group">
    <label>更新时间</label>
    <p><%= @dance_style.updated_at.strftime('%Y-%m-%d %H:%M:%S') %></p>
  </div>
</div>
