<% content_for :title, '街舞分类管理' %>

<div class="card">
  <div class="card-header">
    <h3>街舞分类列表</h3>
    <%= link_to '新建分类', new_admin_dance_style_path, class: 'btn btn-primary' %>
  </div>
  <table class="table">
    <thead>
      <tr>
        <th>名称</th>
        <th>描述</th>
        <th>创建时间</th>
        <th>操作</th>
      </tr>
    </thead>
    <tbody>
      <% @dance_styles.each do |dance_style| %>
        <tr>
          <td><%= dance_style.name %></td>
          <td><%= truncate(dance_style.description, length: 50) %></td>
          <td><%= dance_style.created_at.strftime('%Y-%m-%d %H:%M') %></td>
          <td>
            <%= link_to '查看', admin_dance_style_path(dance_style), class: 'btn btn-primary btn-sm' %>
            <%= link_to '编辑', edit_admin_dance_style_path(dance_style), class: 'btn btn-secondary btn-sm' %>
            <%= link_to '删除', admin_dance_style_path(dance_style), method: :delete, data: { confirm: '确定删除该分类吗？' }, class: 'btn btn-danger btn-sm' %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
  <%= paginate @dance_styles %>
</div>
