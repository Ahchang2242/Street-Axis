<%= form_for([:admin, dance_style], html: { multipart: true }) do |f| %>
  <% if dance_style.errors.any? %>
    <div class="alert alert-danger">
      <h4><%= pluralize(dance_style.errors.count, "error") %> 禁止该内容保存:</h4>
      <ul>
        <% dance_style.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="form-group">
    <%= f.label :name %>
    <%= f.text_field :name, class: 'form-control', required: true %>
  </div>

  <div class="form-group">
    <%= f.label :description %>
    <%= f.text_area :description, class: 'form-control', rows: 5, required: true %>
  </div>

  <%= render 'admin/shared/image_upload', f: f, object: dance_style, remove_image_path: (dance_style.persisted? ? remove_uploaded_image_admin_dance_style_path(dance_style) : nil) %>

  <div class="form-actions">
    <%= f.submit '保存', class: 'btn btn-primary' %>
    <%= link_to '取消', admin_dance_styles_path, class: 'btn btn-secondary' %>
  </div>
<% end %>
