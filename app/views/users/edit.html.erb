<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>编辑资料 - Street Axis</title>
  <%= stylesheet_link_tag 'application', media: 'all', 'data-turbolinks-track': 'reload' %>
  <%= javascript_include_tag 'application', 'data-turbolinks-track': 'reload', 'data-turbolinks-eval': 'false' %>
  <style>
    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }
    
    body {
        font-family: 'Georgia', 'Noto Serif SC', serif;
        line-height: 1.8;
        color: #4A4A4A;
        background-color: #FAF8F5;
    }
    
    .navbar {
        background-color: rgba(250, 248, 245, 0.95);
        backdrop-filter: blur(10px);
        border-bottom: 1px solid rgba(139, 115, 85, 0.1);
        padding: 20px 0;
        position: fixed;
        width: 100%;
        top: 0;
        z-index: 1000;
        transition: all 0.4s ease;
    }
    
    .navbar.scrolled {
        background-color: rgba(250, 248, 245, 0.98);
        padding: 15px 0;
        box-shadow: 0 2px 20px rgba(139, 115, 85, 0.08);
    }
    
    .nav-container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 0 40px;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }
    
    .logo {
        font-size: 28px;
        font-weight: 300;
        color: #8B7355;
        text-decoration: none;
        letter-spacing: 3px;
    }
    
    .nav-menu {
        display: flex;
        list-style: none;
    }
    
    .nav-menu li {
        margin-left: 40px;
    }
    
    .nav-menu a {
        color: #6B6B6B;
        text-decoration: none;
        font-size: 15px;
        transition: color 0.3s ease;
        letter-spacing: 1px;
        font-weight: 300;
    }
    
    .nav-menu a:hover {
        color: #8B7355;
    }
    
    .user-area {
        display: flex;
        align-items: center;
    }
    
    .nav-link {
        color: #6B6B6B;
        text-decoration: none;
        margin-left: 25px;
        font-size: 14px;
        transition: color 0.3s ease;
        letter-spacing: 0.5px;
    }
    
    .nav-link:hover {
        color: #8B7355;
    }
    
    .nav-btn {
        padding: 10px 24px;
        border-radius: 2px;
        font-weight: 400;
        letter-spacing: 1px;
        transition: all 0.3s ease;
        text-decoration: none;
        margin-left: 25px;
        font-size: 14px;
        border: none;
        cursor: pointer;
        font-family: 'Georgia', 'Noto Serif SC', serif;
    }
    
    .nav-btn-primary {
        background-color: #8B7355;
        color: #FFFFFF;
        border: 1px solid #8B7355;
    }
    
    .nav-btn-primary:hover {
        background-color: #6B5B45;
        color: #FFFFFF;
        border-color: #6B5B45;
        transform: translateY(-1px);
    }
    
    .user-dropdown {
        position: relative;
        margin-left: 25px;
        display: inline-block;
        z-index: 1001;
    }
    
    .user-avatar {
        width: 44px;
        height: 44px;
        border-radius: 50%;
        background-color: #8B7355;
        color: #FAF8F5;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 400;
        cursor: pointer;
        font-size: 16px;
        transition: all 0.3s ease;
    }
    
    .user-avatar:hover {
        background-color: #6B5B45;
        transform: scale(1.05);
    }
    
    .dropdown-menu {
        position: absolute;
        top: 100%;
        right: 0;
        background-color: #FAF8F5;
        color: #4A4A4A;
        min-width: 200px;
        box-shadow: 0 4px 30px rgba(139, 115, 85, 0.15);
        border-radius: 4px;
        padding: 8px 0;
        margin-top: 12px;
        visibility: hidden;
        opacity: 0;
        z-index: 9999;
        overflow: hidden;
        transition: all 0.3s ease;
        transform: translateY(-10px);
        pointer-events: none;
        border: 1px solid rgba(139, 115, 85, 0.1);
    }
    
    .dropdown-menu.show {
        visibility: visible;
        opacity: 1;
        transform: translateY(0);
        pointer-events: auto;
    }
    
    .user-info {
        display: flex;
        align-items: center;
        padding: 20px;
        border-bottom: 1px solid rgba(139, 115, 85, 0.1);
    }
    
    .user-avatar-large {
        width: 52px;
        height: 52px;
        border-radius: 50%;
        background-color: #8B7355;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #FAF8F5;
        font-weight: 400;
        font-size: 22px;
        margin-right: 14px;
    }
    
    .user-details {
        flex: 1;
    }
    
    .user-name {
        font-weight: 400;
        font-size: 15px;
        margin-bottom: 4px;
        color: #4A4A4A;
        letter-spacing: 0.5px;
    }
    
    .user-email {
        font-size: 13px;
        color: #8B8B8B;
    }
    
    .menu-divider {
        height: 1px;
        background-color: rgba(139, 115, 85, 0.1);
        margin: 4px 0;
    }
    
    .dropdown-menu .menu-item {
        display: block;
        padding: 12px 24px;
        color: #6B6B6B !important;
        text-decoration: none;
        font-size: 14px;
        transition: all 0.3s ease;
        margin: 0;
        box-sizing: border-box;
        text-align: left;
        letter-spacing: 0.5px;
    }
    
    .dropdown-menu .menu-item:hover {
        background-color: rgba(139, 115, 85, 0.08);
        color: #8B7355 !important;
    }
    
    .dropdown-menu form {
        margin: 0;
        padding: 0;
    }
    
    .logout-btn {
        display: block;
        width: 100%;
        padding: 12px 24px;
        color: #6B6B6B;
        text-decoration: none;
        font-size: 14px;
        background: none;
        border: none;
        cursor: pointer;
        transition: all 0.3s ease;
        margin: 0;
        box-sizing: border-box;
        text-align: left;
        letter-spacing: 0.5px;
    }
    
    .logout-btn:hover {
        background-color: rgba(139, 115, 85, 0.08);
        color: #8B7355;
    }
    
    .main-content {
        padding-top: 120px;
        padding-bottom: 120px;
    }
    
    .container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 0 40px;
    }
    
    .page-header {
        text-align: center;
        margin-bottom: 60px;
    }
    
    .page-header h1 {
        font-size: 48px;
        color: #4A4A4A;
        margin-bottom: 16px;
        font-weight: 300;
        letter-spacing: 2px;
    }
    
    .page-header p {
        font-size: 18px;
        color: #8B8B8B;
        font-weight: 300;
        letter-spacing: 0.5px;
    }
    
    .profile-content {
        display: flex;
        gap: 40px;
    }
    
    .profile-sidebar {
        flex: 0 0 220px;
        background-color: #FFFFFF;
        border-radius: 2px;
        padding: 30px;
        box-shadow: 0 2px 20px rgba(139, 115, 85, 0.08);
        border: 1px solid rgba(139, 115, 85, 0.05);
        height: fit-content;
    }
    
    .profile-sidebar h3 {
        color: #4A4A4A;
        margin-bottom: 24px;
        font-size: 18px;
        font-weight: 400;
        letter-spacing: 0.5px;
    }
    
    .profile-nav {
        list-style: none;
    }
    
    .profile-nav li {
        margin-bottom: 8px;
    }
    
    .profile-nav a {
        display: block;
        padding: 12px 16px;
        color: #6B6B6B;
        text-decoration: none;
        border-radius: 2px;
        transition: all 0.3s ease;
        font-size: 14px;
        letter-spacing: 0.5px;
        font-weight: 300;
    }
    
    .profile-nav a:hover {
        background-color: rgba(139, 115, 85, 0.08);
        color: #8B7355;
    }
    
    .profile-nav a.active {
        background-color: #8B7355;
        color: #FAF8F5;
    }
    
    .profile-main {
        flex: 1;
        background-color: #FFFFFF;
        border-radius: 2px;
        padding: 40px;
        box-shadow: 0 2px 20px rgba(139, 115, 85, 0.08);
        border: 1px solid rgba(139, 115, 85, 0.05);
    }
    
    .section-title {
        color: #4A4A4A;
        margin-bottom: 30px;
        font-size: 24px;
        border-bottom: 1px solid rgba(139, 115, 85, 0.15);
        padding-bottom: 16px;
        font-weight: 400;
        letter-spacing: 0.5px;
    }
    
    .form-group {
        margin-bottom: 24px;
    }
    
    .form-group label {
        display: block;
        margin-bottom: 10px;
        color: #6B6B6B;
        font-size: 15px;
        font-weight: 300;
        letter-spacing: 0.5px;
    }
    
    .form-group input {
        width: 100%;
        padding: 14px 18px;
        border: 1px solid rgba(139, 115, 85, 0.2);
        border-radius: 2px;
        font-size: 15px;
        font-family: 'Georgia', 'Noto Serif SC', serif;
        color: #4A4A4A;
        background-color: #FAF8F5;
        transition: all 0.3s ease;
    }
    
    .form-group input:focus {
        outline: none;
        border-color: #8B7355;
        background-color: #FFFFFF;
    }
    
    .error-message {
        background-color: rgba(200, 40, 40, 0.1);
        color: #c62828;
        padding: 16px 20px;
        border-radius: 2px;
        margin-bottom: 30px;
        font-size: 14px;
        letter-spacing: 0.5px;
        border: 1px solid rgba(200, 40, 40, 0.2);
    }
    
    .error-field {
        border-color: #c62828 !important;
    }
    
    .btn {
        display: inline-block;
        padding: 12px 28px;
        border: none;
        border-radius: 2px;
        font-size: 14px;
        font-weight: 400;
        cursor: pointer;
        transition: all 0.3s ease;
        text-decoration: none;
        letter-spacing: 1px;
    }
    
    .btn-primary {
        background-color: #8B7355;
        color: #FAF8F5;
        border: 1px solid #8B7355;
    }
    
    .btn-primary:hover {
        background-color: #6B5B45;
        border-color: #6B5B45;
        transform: translateY(-1px);
    }
    
    .btn-secondary {
        background-color: transparent;
        color: #8B7355;
        border: 1px solid #8B7355;
    }
    
    .btn-secondary:hover {
        background-color: #8B7355;
        color: #FAF8F5;
    }
    
    .back-link {
        display: inline-block;
        margin-top: 40px;
        color: #8B7355;
        text-decoration: none;
        font-size: 15px;
        transition: color 0.3s ease;
        letter-spacing: 0.5px;
    }
    
    .back-link:hover {
        color: #6B5B45;
    }
    
    @media (max-width: 768px) {
        .nav-menu {
            display: none;
        }
        
        .nav-container {
            padding: 0 20px;
        }
        
        .main-content {
            padding-top: 100px;
            padding-bottom: 80px;
        }
        
        .container {
            padding: 0 20px;
        }
        
        .page-header h1 {
            font-size: 36px;
        }
        
        .profile-content {
            flex-direction: column;
        }
        
        .profile-sidebar {
            flex: 1;
        }
    }
  </style>
</head>
<body>
    <nav class="navbar" id="navbar">
        <div class="nav-container">
            <a href="<%= root_path %>" class="logo">Street Axis</a>
            
            <ul class="nav-menu">
                <li><%= link_to "首页", root_path %></li>
                <li><%= link_to "街舞分类", categories_path %></li>
                <li><%= link_to "最新活动", events_path %></li>
                <li><%= link_to "关于我们", about_path %></li>
                <li><%= link_to "联系我们", contact_path %></li>
            </ul>
            
            <div class="user-area">
                <% if !user_signed_in? %>
                <%= link_to "注册", new_user_registration_path, class: "nav-link" %>
                <%= link_to "登录", new_user_session_path, class: "nav-btn nav-btn-primary" %>
                <% else %>
                <div class="user-dropdown">
                    <div class="user-avatar" id="user-avatar">
                        <% if current_user.avatar.attached? %>
                            <%= image_tag current_user.avatar.variant(resize_to_fill: [44, 44]), style: 'width: 44px; height: 44px; border-radius: 50%; object-fit: cover;' %>
                        <% else %>
                            <%= current_user.email.first.upcase %>
                        <% end %>
                    </div>
                    <div class="dropdown-menu">
                        <div class="user-info">
                            <div class="user-avatar-large">
                                <% if current_user.avatar.attached? %>
                                    <%= image_tag current_user.avatar.variant(resize_to_fill: [52, 52]), style: 'width: 52px; height: 52px; border-radius: 50%; object-fit: cover;' %>
                                <% else %>
                                    <%= current_user.email.first.upcase %>
                                <% end %>
                            </div>
                            <div class="user-details">
                                <div class="user-name"><%= current_user.username || current_user.email.split('@').first %></div>
                                <div class="user-email"><%= current_user.email %></div>
                            </div>
                        </div>
                        <div class="menu-divider"></div>
                        <a href="<%= user_profile_path %>" class="menu-item">个人中心</a>
                        <a href="<%= user_courses_path %>" class="menu-item">我的课程</a>
                        <div class="menu-divider"></div>
                        <%= form_for(current_user, as: :user, url: destroy_user_session_path, method: :delete) do |f| %>
                            <button type="submit" class="menu-item logout-btn">退出登录</button>
                        <% end %>
                    </div>
                </div>
                <% end %>
            </div>
        </div>
    </nav>
    
    <main class="main-content">
        <div class="container">
            <div class="page-header">
                <h1>个人中心</h1>
                <p>管理你的账号信息和个人资料</p>
            </div>
            
            <div class="profile-content">
                <div class="profile-sidebar">
                    <h3>账户管理</h3>
                    <ul class="profile-nav">
                        <li><a href="<%= user_profile_path %>">个人信息</a></li>
                        <li><a href="<%= edit_user_profile_path %>" class="active">编辑资料</a></li>
                        <li><a href="<%= user_security_path %>">账号安全</a></li>
                        <li><a href="<%= user_courses_path %>">我的课程</a></li>
                    </ul>
                </div>
                
                <div class="profile-main">
                    <h2 class="section-title">编辑资料</h2>
                    
                    <% if @user.errors.any? %>
                    <div class="error-message">
                        <%= @user.errors.full_messages.join('<br>').html_safe %>
                    </div>
                    <% end %>
                    
                    <%= form_for(@user, as: :user, url: update_user_profile_path, method: :patch, html: { multipart: true }) do |f| %>
                        <div class="form-group">
                            <%= f.label :avatar, '头像' %>
                            <div style="margin-bottom: 16px;">
                                <% if @user.avatar.attached? %>
                                    <%= image_tag @user.avatar.variant(resize_to_fill: [150, 150]), id: 'avatar-preview', class: 'avatar-preview', style: 'border-radius: 50%; width: 150px; height: 150px; object-fit: cover;' %>
                                <% else %>
                                    <div id="avatar-preview" class="avatar-preview" style="width: 150px; height: 150px; border-radius: 50%; background-color: #8B7355; display: flex; align-items: center; justify-content: center; color: #FAF8F5; font-size: 48px;">
                                        <%= @user.email.first.upcase %>
                                    </div>
                                <% end %>
                            </div>
                            <%= f.file_field :avatar, id: 'avatar-input', accept: 'image/jpeg,image/png,image/jpg' %>
                            <small style="color: #8B8B8B; display: block; margin-top: 8px;">支持 JPG、PNG 格式，大小不超过 5MB</small>
                        </div>
                        
                        <div class="form-group">
                            <%= f.label :username, '用户名' %>
                            <%= f.text_field :username, class: @user.errors.include?(:username) ? 'error-field' : '' %>
                            <small style="color: #8B8B8B; display: block; margin-top: 8px;">3-50个字符，只能包含字母、数字、下划线和中文</small>
                        </div>
                        
                        <div class="form-group">
                            <%= f.label :email, '邮箱地址' %>
                            <%= f.email_field :email, class: @user.errors.include?(:email) ? 'error-field' : '' %>
                        </div>
                        
                        <div class="form-group">
                            <%= f.label :bio, '个性签名' %>
                            <%= f.text_area :bio, rows: 4, class: @user.errors.include?(:bio) ? 'error-field' : '', style: 'width: 100%; padding: 14px 18px; border: 1px solid rgba(139, 115, 85, 0.2); border-radius: 2px; font-size: 15px; font-family: Georgia, "Noto Serif SC", serif; color: #4A4A4A; background-color: #FAF8F5; resize: vertical;' %>
                            <small style="color: #8B8B8B; display: block; margin-top: 8px;">最多 200 个字符</small>
                        </div>
                        
                        <div class="form-group">
                            <%= f.submit '保存更改', class: 'btn btn-primary' %>
                            <%= link_to '取消', user_profile_path, class: 'btn btn-secondary', style: 'margin-left: 12px;' %>
                        </div>
                    <% end %>
                </div>
            </div>
            
            <div style="text-align: center;">
                <%= link_to "← 返回首页", root_path, class: "back-link" %>
            </div>
        </div>
    </main>
    
    <script data-turbolinks-eval="false">
        window.addEventListener('scroll', function() {
            const navbar = document.getElementById('navbar');
            if (navbar && window.scrollY > 50) {
                navbar.classList.add('scrolled');
            } else if (navbar) {
                navbar.classList.remove('scrolled');
            }
        });
        
        function initAvatarPreview() {
            const avatarInput = document.getElementById('avatar-input');
            const avatarPreview = document.getElementById('avatar-preview');
            
            if (avatarInput && avatarPreview) {
                avatarInput.addEventListener('change', function(e) {
                    const file = e.target.files[0];
                    if (file) {
                        const reader = new FileReader();
                        reader.onload = function(event) {
                            avatarPreview.innerHTML = '';
                            avatarPreview.style.backgroundImage = 'url(' + event.target.result + ')';
                            avatarPreview.style.backgroundSize = 'cover';
                            avatarPreview.style.backgroundPosition = 'center';
                            avatarPreview.style.borderRadius = '50%';
                            avatarPreview.style.width = '150px';
                            avatarPreview.style.height = '150px';
                        };
                        reader.readAsDataURL(file);
                    }
                });
            }
        }
        
        function initUserDropdown() {
            const userDropdown = document.querySelector('.user-dropdown');
            const dropdownMenu = document.querySelector('.dropdown-menu');
            let isOpenByClick = false;
            let hoverTimeout;
            
            if (userDropdown && dropdownMenu) {
                userDropdown.setAttribute('tabindex', '0');
                userDropdown.setAttribute('role', 'button');
                userDropdown.setAttribute('aria-haspopup', 'true');
                userDropdown.setAttribute('aria-expanded', 'false');
                
                function handleClick(e) {
                    e.stopPropagation();
                    isOpenByClick = !isOpenByClick;
                    dropdownMenu.classList.toggle('show');
                    userDropdown.setAttribute('aria-expanded', dropdownMenu.classList.contains('show'));
                }
                
                function handleMouseEnter() {
                    clearTimeout(hoverTimeout);
                    if (!isOpenByClick) {
                        dropdownMenu.classList.add('show');
                        userDropdown.setAttribute('aria-expanded', 'true');
                    }
                }
                
                function handleMouseLeave() {
                    if (!isOpenByClick) {
                        hoverTimeout = setTimeout(() => {
                            dropdownMenu.classList.remove('show');
                            userDropdown.setAttribute('aria-expanded', 'false');
                        }, 200);
                    }
                }
                
                function handleClickOutside(e) {
                    if (!userDropdown.contains(e.target) && !dropdownMenu.contains(e.target)) {
                        dropdownMenu.classList.remove('show');
                        isOpenByClick = false;
                        userDropdown.setAttribute('aria-expanded', 'false');
                    }
                }
                
                function handleKeyDown(e) {
                    if (e.key === 'Enter' || e.key === ' ') {
                        e.preventDefault();
                        handleClick(e);
                    } else if (e.key === 'Escape') {
                        dropdownMenu.classList.remove('show');
                        isOpenByClick = false;
                        userDropdown.setAttribute('aria-expanded', 'false');
                    }
                }
                
                userDropdown.addEventListener('click', handleClick);
                userDropdown.addEventListener('mouseenter', handleMouseEnter);
                userDropdown.addEventListener('mouseleave', handleMouseLeave);
                dropdownMenu.addEventListener('mouseenter', handleMouseEnter);
                dropdownMenu.addEventListener('mouseleave', handleMouseLeave);
                userDropdown.addEventListener('keydown', handleKeyDown);
                document.addEventListener('click', handleClickOutside);
            }
        }
        
        function initLogout() {
            const logoutBtn = document.querySelector('.logout-btn');
            const logoutForm = document.querySelector('.dropdown-menu form');
            
            if (logoutBtn && logoutForm) {
                function handleLogoutClick(e) {
                    e.stopPropagation();
                    logoutForm.submit();
                }
                
                logoutBtn.addEventListener('click', handleLogoutClick);
            }
        }
        
        function initPage() {
            initUserDropdown();
            initLogout();
            initAvatarPreview();
        }
        
        document.addEventListener('DOMContentLoaded', initPage);
        document.addEventListener('turbolinks:load', initPage);
    </script>
</body>
</html>
