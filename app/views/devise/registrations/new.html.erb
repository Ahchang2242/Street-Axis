<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>注册 - Street Axis</title>
    <%= stylesheet_link_tag 'application', media: 'all', 'data-turbolinks-track': 'reload' %>
    <%= javascript_include_tag 'application', 'data-turbolinks-track': 'reload' %>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        body {
            font-family: 'Georgia', 'Noto Serif SC', serif;
            background-color: #FAF8F5;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 40px 20px;
        }
        
        .container {
            position: relative;
            width: 100%;
            max-width: 440px;
        }
        
        .header {
            text-align: center;
            margin-bottom: 40px;
        }
        
        .logo {
            font-size: 32px;
            font-weight: 300;
            color: #8B7355;
            letter-spacing: 3px;
            text-decoration: none;
        }
        
        .register-form {
            background: #FFFFFF;
            padding: 48px 40px;
            border-radius: 2px;
            box-shadow: 0 2px 20px rgba(139, 115, 85, 0.08);
            text-align: center;
            border: 1px solid rgba(139, 115, 85, 0.05);
        }
        
        .register-form h2 {
            margin-bottom: 16px;
            color: #4A4A4A;
            font-size: 24px;
            font-weight: 400;
            letter-spacing: 1px;
        }
        
        .register-form p {
            margin-bottom: 32px;
            color: #8B8B8B;
            font-size: 15px;
            font-weight: 300;
        }
        
        .success-message {
            background-color: rgba(139, 115, 85, 0.08);
            color: #8B7355;
            padding: 14px 18px;
            border-radius: 2px;
            margin-bottom: 24px;
            font-size: 14px;
            text-align: left;
        }
        
        .form-group {
            margin-bottom: 24px;
            text-align: left;
        }
        
        .form-group label {
            display: block;
            margin-bottom: 10px;
            color: #6B6B6B;
            font-size: 14px;
            font-weight: 400;
            letter-spacing: 0.5px;
        }
        
        .form-group input {
            width: 100%;
            padding: 14px 18px;
            border: 1px solid rgba(139, 115, 85, 0.2);
            border-radius: 2px;
            font-size: 15px;
            color: #4A4A4A;
            background-color: #FAF8F5;
            transition: all 0.3s ease;
            font-family: 'Georgia', 'Noto Serif SC', serif;
            letter-spacing: 0.3px;
        }
        
        .form-group input:focus {
            outline: none;
            border-color: #8B7355;
            background-color: #FFFFFF;
        }
        
        .form-group input::placeholder {
            color: #9B9B9B;
            font-weight: 300;
        }
        
        .password-container {
            position: relative;
        }
        
        .password-toggle {
            position: absolute;
            right: 18px;
            top: 50%;
            transform: translateY(-50%);
            cursor: pointer;
            color: #8B7355;
            font-size: 18px;
            transition: opacity 0.3s ease;
        }
        
        .password-toggle:hover {
            opacity: 0.7;
        }
        
        .btn-primary {
            width: 100%;
            padding: 16px;
            background-color: #8B7355;
            color: #FAF8F5;
            border: none;
            border-radius: 2px;
            font-size: 15px;
            font-weight: 400;
            cursor: pointer;
            transition: all 0.3s ease;
            letter-spacing: 1px;
            text-transform: uppercase;
            font-family: 'Georgia', 'Noto Serif SC', serif;
        }
        
        .btn-primary:hover {
            background-color: #6B5B45;
            transform: translateY(-1px);
            box-shadow: 0 8px 20px rgba(139, 115, 85, 0.3);
        }
        
        .form-links {
            margin-top: 28px;
            font-size: 14px;
        }
        
        .form-links p {
            margin-bottom: 0;
        }
        
        .form-links a {
            color: #8B7355;
            text-decoration: none;
            transition: color 0.3s ease;
            font-weight: 400;
        }
        
        .form-links a:hover {
            color: #6B5B45;
        }
        
        .error-message {
            background-color: rgba(200, 50, 50, 0.08);
            color: #8B3A3A;
            padding: 14px 18px;
            border-radius: 2px;
            margin-bottom: 24px;
            font-size: 14px;
            text-align: left;
        }
        
        .back-link {
            display: inline-block;
            margin-top: 24px;
            color: #8B7355;
            text-decoration: none;
            font-size: 14px;
            transition: color 0.3s ease;
            letter-spacing: 0.5px;
        }
        
        .back-link:hover {
            color: #6B5B45;
        }
        
        @media (max-width: 768px) {
            .register-form {
                padding: 36px 28px;
            }
            
            .container {
                max-width: 100%;
            }
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="header">
            <a href="<%= root_path %>" class="logo">Street Axis</a>
        </div>
        
        <div class="register-form">
            <h2>注册新账号</h2>
            <p>填写以下信息创建您的账户</p>
            
            <% if resource.errors.any? %>
            <div class="error-message">
                <%= resource.errors.full_messages.first %>
            </div>
            <% end %>
            
            <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { id: 'register-form' }) do |f| %>
                <div class="form-group">
                    <label for="<%= resource_name %>_username">用户名</label>
                    <%= f.text_field :username, placeholder: "请输入用户名", class: "form-control" %>
                </div>
                
                <div class="form-group">
                    <label for="<%= resource_name %>_email">邮箱</label>
                    <%= f.email_field :email, autofocus: true, autocomplete: "email", placeholder: "请输入邮箱", class: "form-control" %>
                </div>
                
                <div class="form-group">
                    <label for="<%= resource_name %>_password">密码</label>
                    <div class="password-container">
                        <%= f.password_field :password, autocomplete: "new-password", placeholder: "请输入密码（至少8位）", class: "form-control" %>
                        <span class="password-toggle" onclick="togglePassword('<%= resource_name %>_password')">👁️</span>
                    </div>
                </div>
                
                <div class="form-group">
                    <label for="<%= resource_name %>_password_confirmation">确认密码</label>
                    <div class="password-container">
                        <%= f.password_field :password_confirmation, autocomplete: "new-password", placeholder: "请再次输入密码", class: "form-control" %>
                        <span class="password-toggle" onclick="togglePassword('<%= resource_name %>_password_confirmation')">👁️</span>
                    </div>
                </div>
                
                <%= f.submit "注册", class: "btn-primary" %>
                
                <div class="form-links">
                    <p>已有账号？ <%= link_to "立即登录", new_session_path(resource_name) %></p>
                </div>
            <% end %>
            
            <a href="<%= root_path %>" class="back-link">← 返回首页</a>
        </div>
    </div>
    
    <script>
        // 切换密码显示/隐藏
        function togglePassword(fieldId) {
            const passwordInput = document.getElementById(fieldId);
            const passwordToggle = passwordInput.nextElementSibling;
            
            if (passwordInput.type === 'password') {
                passwordInput.type = 'text';
                passwordToggle.textContent = '👁️‍🗨️';
            } else {
                passwordInput.type = 'password';
                passwordToggle.textContent = '👁️';
            }
        }
    </script>
</body>
</html>
