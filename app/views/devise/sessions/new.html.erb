<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>登录 - 街舞网站</title>
    <%= stylesheet_link_tag 'application', media: 'all', 'data-turbolinks-track': 'reload' %>
    <%= javascript_include_tag 'application', 'data-turbolinks-track': 'reload' %>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        body {
            font-family: 'Arial', sans-serif;
            background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 20px;
        }
        
        .container {
            position: relative;
            width: 100%;
            max-width: 400px;
        }
        
        .header {
            text-align: center;
            margin-bottom: 30px;
        }
        
        .logo {
            font-size: 24px;
            font-weight: bold;
            color: #333;
        }
        
        .login-form {
            background: white;
            padding: 40px;
            border-radius: 8px;
            box-shadow: 0 5px 15px rgba(0, 0, 0, 0.1);
            text-align: center;
        }
        
        .login-form h2 {
            margin-bottom: 20px;
            color: #333;
            font-size: 20px;
        }
        
        .login-form p {
            margin-bottom: 30px;
            color: #666;
            font-size: 14px;
        }
        
        .form-group {
            margin-bottom: 20px;
            text-align: left;
        }
        
        .form-group label {
            display: block;
            margin-bottom: 8px;
            color: #666;
            font-size: 14px;
        }
        
        .form-group input {
            width: 100%;
            padding: 12px 15px;
            border: 1px solid #ddd;
            border-radius: 4px;
            font-size: 14px;
            transition: border-color 0.3s;
        }
        
        .form-group input:focus {
            outline: none;
            border-color: #888;
        }
        
        .password-container {
            position: relative;
        }
        
        .password-toggle {
            position: absolute;
            right: 15px;
            top: 50%;
            transform: translateY(-50%);
            cursor: pointer;
            color: #888;
        }
        
        .remember-me {
            display: flex;
            align-items: center;
            margin-bottom: 20px;
            font-size: 14px;
        }
        
        .remember-me input {
            margin-right: 8px;
        }
        
        .remember-me label {
            color: #666;
            cursor: pointer;
        }
        
        .btn-primary {
            width: 100%;
            padding: 12px;
            background-color: #8B4513;
            color: white;
            border: none;
            border-radius: 4px;
            font-size: 16px;
            font-weight: bold;
            cursor: pointer;
            transition: background-color 0.3s;
        }
        
        .btn-primary:hover {
            background-color: #6B3410;
        }
        
        .form-links {
            margin-top: 20px;
            font-size: 14px;
        }
        
        .form-links a {
            color: #888;
            text-decoration: none;
            margin: 0 10px;
            transition: color 0.3s;
        }
        
        .form-links a:hover {
            color: #333;
        }
        
        .form-links .register-btn {
            background-color: #f0f0f0;
            padding: 8px 16px;
            border-radius: 4px;
            font-weight: bold;
        }
        
        .form-links .register-btn:hover {
            background-color: #e0e0e0;
        }
        
        .error-message {
            background-color: #ffebee;
            color: #c62828;
            padding: 10px;
            border-radius: 4px;
            margin-bottom: 20px;
            font-size: 14px;
        }
        
        .success-message {
            background-color: #e8f5e8;
            color: #2e7d32;
            padding: 10px;
            border-radius: 4px;
            margin-bottom: 20px;
            font-size: 14px;
        }
        
        @media (max-width: 768px) {
            .login-form {
                padding: 30px 20px;
            }
            
            .container {
                max-width: 100%;
            }
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="header">
            <div class="logo">IN ONE</div>
        </div>
        
        <div class="login-form">
            <h2>登录</h2>
            <p>输入您的用户名和密码以访问您的账户</p>
            
            <% if resource.errors.any? %>
            <div class="error-message">
                <%= resource.errors.full_messages.first %>
            </div>
            <% elsif flash[:notice] %>
            <div class="success-message">
                <%= flash[:notice] %>
            </div>
            <% elsif flash[:alert] %>
            <div class="error-message">
                <%= flash[:alert] %>
            </div>
            <% end %>
            
            <%= form_for(resource, as: resource_name, url: session_path(resource_name), html: { id: 'login-form' }) do |f| %>
                <div class="form-group">
                    <label for="<%= resource_name %>_email">用户名/邮箱</label>
                    <%= f.email_field :email, autofocus: true, autocomplete: "email", placeholder: "请输入用户名或邮箱", class: "form-control" %>
                </div>
                
                <div class="form-group">
                    <label for="<%= resource_name %>_password">密码</label>
                    <div class="password-container">
                        <%= f.password_field :password, autocomplete: "current-password", placeholder: "请输入密码", class: "form-control" %>
                        <span class="password-toggle" onclick="togglePassword()">👁️</span>
                    </div>
                </div>
                
                <% if devise_mapping.rememberable? %>
                <div class="remember-me">
                    <%= f.check_box :remember_me %>
                    <%= f.label :remember_me %>
                </div>
                <% end %>
                
                <%= f.submit "登录", class: "btn-primary" %>
                
                <div class="form-links">
                    <%= link_to "忘记密码？", new_password_path(resource_name) %>
                    <%= link_to "注册新账号", new_registration_path(resource_name), class: "register-btn" %>
                </div>
            <% end %>
        </div>
    </div>
    
    <script>
        // 切换密码显示/隐藏
        function togglePassword() {
            // 通过父元素定位密码输入框，更稳定
            const passwordContainer = document.querySelector('.password-container');
            const passwordInput = passwordContainer.querySelector('input');
            const passwordToggle = passwordContainer.querySelector('.password-toggle');
            
            if (passwordInput && passwordToggle) {
                if (passwordInput.type === 'password') {
                    passwordInput.type = 'text';
                    passwordToggle.textContent = '👁️‍🗨️';
                } else {
                    passwordInput.type = 'password';
                    passwordToggle.textContent = '👁️';
                }
            }
        }
    </script>
</body>
</html>
